<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TERMINAL</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #000;
            color: #0f0;
            font-family: 'Courier New', monospace;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 1200px;
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
            border-bottom: 2px solid #0f0;
            padding-bottom: 20px;
            font-size: 24px;
            letter-spacing: 3px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(60px, 1fr));
            gap: 8px;
            justify-items: center;
        }

        .box-btn {
            width: 60px;
            height: 60px;
            background-color: #000;
            border: 2px solid #0f0;
            color: #0f0;
            font-family: 'Courier New', monospace;
            font-size: 12px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.1s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .box-btn:hover {
            background-color: #0f0;
            color: #000;
            box-shadow: 0 0 10px #0f0;
        }

        .box-btn.active {
            background-color: #0f0;
            color: #000;
            box-shadow: 0 0 10px #0f0;
        }

        .box-btn.music-enabled {
            border-color: #0f0;
        }

        .box-btn.music-enabled:active {
            box-shadow: 0 0 15px #0f0, inset 0 0 10px #0f0;
        }

        /* Password modal */
        .modal {
            display: flex;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.9);
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background-color: #000;
            border: 3px solid #0f0;
            padding: 40px;
            text-align: center;
            max-width: 400px;
            box-shadow: 0 0 20px #0f0;
        }

        .modal-content h1 {
            color: #0f0;
            margin-bottom: 30px;
            font-size: 20px;
            letter-spacing: 2px;
        }

        .modal-content input {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            background-color: #000;
            border: 2px solid #0f0;
            color: #0f0;
            font-family: 'Courier New', monospace;
            font-size: 14px;
        }

        .modal-content input::placeholder {
            color: #0f0;
            opacity: 0.5;
        }

        .modal-content button {
            width: 100%;
            padding: 12px;
            background-color: #000;
            border: 2px solid #0f0;
            color: #0f0;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            letter-spacing: 1px;
        }

        .modal-content button:hover {
            background-color: #0f0;
            color: #000;
            box-shadow: 0 0 10px #0f0;
        }

        .error-message {
            color: #0f0;
            margin-top: 15px;
            font-size: 12px;
            display: none;
        }

        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>
    <!-- Password Modal -->
    <div id="passwordModal" class="modal">
        <div class="modal-content">
            <h1>ACCESS REQUIRED</h1>
            <input 
                type="password" 
                id="passwordInput" 
                placeholder="ENTER PASSWORD" 
                autocomplete="off"
            >
            <button onclick="checkPassword()">ENTER</button>
            <div class="error-message" id="errorMessage">INVALID PASSWORD</div>
        </div>
    </div>

    <!-- Main Content -->
    <div id="mainContent" class="hidden">
        <div class="container">
            <div class="header">[ SOUND TERMINAL ]</div>
            <div class="grid" id="grid"></div>
        </div>
    </div>

    <script>
        const PASSWORD = "kewl69"; // Change this to your desired password
        let accessGranted = false;

        // Initialize password protection
        document.getElementById("passwordInput").addEventListener("keypress", function(event) {
            if (event.key === "Enter") {
                checkPassword();
            }
        });

        function checkPassword() {
            const input = document.getElementById("passwordInput").value;
            const errorMsg = document.getElementById("errorMessage");

            if (input === PASSWORD) {
                accessGranted = true;
                document.getElementById("passwordModal").classList.add("hidden");
                document.getElementById("mainContent").classList.remove("hidden");
                initializeGrid();
                document.getElementById("passwordInput").value = ""; // Clear input
            } else {
                errorMsg.style.display = "block";
                document.getElementById("passwordInput").value = "";
                document.getElementById("passwordInput").focus();
            }
        }

        function initializeGrid() {
            const grid = document.getElementById("grid");
            grid.innerHTML = ""; // Clear existing grid

            // Generate 112 buttons with numbers 345-456
            for (let i = 0; i < 112; i++) {
                const number = 345 + i;
                const btn = document.createElement("button");
                btn.className = "box-btn";
                btn.textContent = number;
                btn.dataset.number = number;

                // Check if divisible by 7
                if (number % 7 === 0) {
                    btn.classList.add("music-enabled");
                    btn.addEventListener("click", function() {
                        playMusic(number);
                    });
                } else {
                    btn.addEventListener("click", function() {
                        showActive(this);
                    });
                }

                grid.appendChild(btn);
            }
        }

        function playMusic(number) {
            const btn = document.querySelector(`[data-number="${number}"]`);
            
            // Show active state
            btn.classList.add("active");
            
            // Try to play music file
            const musicFile = `music_${number}.mp3`; // Adjust extension as needed
            const audio = new Audio(musicFile);
            audio.play().catch(err => {
                console.log(`Music file not found or error: ${musicFile}`);
            });

            // Remove active state after animation
            setTimeout(() => {
                btn.classList.remove("active");
            }, 200);
        }

        function showActive(btn) {
            btn.classList.add("active");
            setTimeout(() => {
                btn.classList.remove("active");
            }, 150);
        }

        // Focus password input on load
        window.addEventListener("load", function() {
            document.getElementById("passwordInput").focus();
        });
    </script>
</body>
</html>